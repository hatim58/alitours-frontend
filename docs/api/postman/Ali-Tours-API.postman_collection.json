{
  "info": {
    "name": "Ali Tours & Travels API",
    "description": "Complete API collection for Ali Tours & Travels travel management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.alitourstravels.in/v1",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"info@alitourstravels.in\",\n  \"password\": \"Yaalimadad@53\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": [
            {
              "name": "Successful Login",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "login"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": {\n      \"id\": \"user_123\",\n      \"name\": \"John Doe\",\n      \"email\": \"user@example.com\",\n      \"role\": \"user\"\n    }\n  }\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data.token) {",
                  "        pm.collectionVariables.set('authToken', response.data.token);",
                  "        pm.test('Login successful', () => {",
                  "            pm.expect(response.success).to.be.true;",
                  "        });",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+91 9876543210\",\n  \"address\": \"123 Test Street, Test City\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Tour Packages",
      "item": [
        {
          "name": "Get All Packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/packages?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["packages"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "destination",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "duration",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has packages array', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.data.packages).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Package by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/packages/shimla-explorer",
              "host": ["{{baseUrl}}"],
              "path": ["packages", "shimla-explorer"]
            }
          }
        },
        {
          "name": "Create Package (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Package\",\n  \"destination\": \"Test Destination\",\n  \"description\": \"A test package for API documentation purposes. This package includes all the basic features and amenities.\",\n  \"duration\": 5,\n  \"price\": 25000,\n  \"originalPrice\": 30000,\n  \"maxGuests\": 10,\n  \"image\": \"https://images.pexels.com/photos/2440024/pexels-photo-2440024.jpeg\",\n  \"highlights\": [\n    \"Test highlight 1\",\n    \"Test highlight 2\"\n  ],\n  \"includes\": [\n    \"Test inclusion 1\",\n    \"Test inclusion 2\"\n  ],\n  \"excludes\": [\n    \"Test exclusion 1\",\n    \"Test exclusion 2\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/packages",
              "host": ["{{baseUrl}}"],
              "path": ["packages"]
            }
          }
        },
        {
          "name": "Search Packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/packages/search?q=shimla&destination=Himachal",
              "host": ["{{baseUrl}}"],
              "path": ["packages", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "shimla"
                },
                {
                  "key": "destination",
                  "value": "Himachal"
                }
              ]
            }
          }
        }
      ]
    },
